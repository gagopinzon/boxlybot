# Variables para Boxlybot corriendo junto a Hermes en el mismo servidor.
# Hermes y Next deben usar la MISMA ruta para los JSON.

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Obligatorio recomendado en producción: ruta absoluta única (ej. donde Hermes escribe).
# Ejemplo: /srv/hermes/data  o  /home/hermes/app/data
HERMES_DATA_DIR=/ruta/compartida/hermes-data

# Alternativa si prefieres otro nombre:
# BOXLYBOT_DATA_DIR=/ruta/compartida/hermes-data
