# Ejemplo: Nginx del mismo servidor que Hermes — proxy al proceso Node (standalone).
# Ajusta server_name y el puerto upstream.

upstream boxlybot_next {
    server 127.0.0.1:3000;
}

server {
    listen 443 ssl;
    server_name dashboard.tu-dominio.com;

    location / {
        proxy_pass http://boxlybot_next;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
